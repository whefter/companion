{
  "name": "the-companion",
  "version": "0.82.0",
  "type": "module",
  "description": "Web UI for launching and interacting with Claude Code agents",
  "license": "MIT",
  "author": "The Vibe Company",
  "bin": {
    "the-companion": "./bin/cli.ts",
    "companion": "./bin/cli.ts"
  },
  "files": [
    "bin/",
    "server/",
    "dist/"
  ],
  "engines": {
    "bun": ">=1.0.0"
  },
  "keywords": [
    "claude",
    "claude-code",
    "ai",
    "agent",
    "web-ui",
    "vibe-coding"
  ],
  "scripts": {
    "dev": "bun dev.ts",
    "dev:api": "bun --watch server/index.ts",
    "dev:vite": "vite",
    "build": "vite build",
    "start": "NODE_ENV=production bun server/index.ts",
    "prepublishOnly": "bun run build",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:a11y": "vitest run --testNamePattern='axe accessibility|accessible names|aria-expanded'",
    "test:codex-contract": "vitest run server/codex-protocol-*.test.ts",
    "generate-token": "bun bin/generate-token.ts"
  },
  "dependencies": {
    "@codemirror/lang-cpp": "^6.0.3",
    "@codemirror/lang-css": "^6.3.1",
    "@codemirror/lang-html": "^6.4.11",
    "@codemirror/lang-java": "^6.0.2",
    "@codemirror/lang-javascript": "^6.2.4",
    "@codemirror/lang-json": "^6.0.2",
    "@codemirror/lang-markdown": "^6.5.0",
    "@codemirror/lang-python": "^6.2.1",
    "@codemirror/lang-rust": "^6.0.2",
    "@codemirror/lang-sql": "^6.10.0",
    "@codemirror/lang-xml": "^6.1.0",
    "@codemirror/lang-yaml": "^6.1.2",
    "@codemirror/view": "^6.39.15",
    "@uiw/react-codemirror": "^4.25.4",
    "croner": "^10.0.1",
    "diff": "^8.0.3",
    "fzf": "^0.5.2",
    "hono": "^4.7.0",
    "posthog-js": "^1.347.2",
    "qrcode": "^1.5.4",
    "ws": "^8.19.0"
  },
  "devDependencies": {
    "@tailwindcss/vite": "^4.0.0",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.2",
    "@testing-library/user-event": "^14.6.1",
    "@types/bun": "^1.2.5",
    "@types/diff": "^8.0.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.0.0",
    "@types/react-dom": "^19.0.0",
    "@types/ws": "^8.18.1",
    "@vitejs/plugin-react": "^4.4.0",
    "@vitest/coverage-v8": "^4.0.18",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "autoprefixer": "^10.4.21",
    "jsdom": "^28.0.0",
    "postcss": "^8.5.3",
    "react": "^19.0.0",
    "react-arborist": "^3.4.3",
    "react-dom": "^19.0.0",
    "react-markdown": "^10.1.0",
    "react-resizable-panels": "^4.6.2",
    "remark-gfm": "^4.0.1",
    "tailwindcss": "^4.0.0",
    "typescript": "^5.9.3",
    "vite": "^6.3.0",
    "vite-plugin-pwa": "^1.2.0",
    "vitest": "^4.0.18",
    "vitest-axe": "^0.1.0",
    "zustand": "^5.0.0"
  }
}
